generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id
  name        String
  category    String   
  basePrice   Float
  description String?
  isCombo     Boolean  @default(false)
  isAvailable Boolean  @default(true) 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Modifier {
  id          String   @id @default(uuid())
  name        String
  type        String   
  price       Float    @default(0)
  isAvailable Boolean  @default(true) 
  createdAt   DateTime @default(now())
}

// EL NUEVO CRM DE CLIENTES
model Customer {
  phone     String   @id
  name      String?
  points    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id             String   @id @default(uuid())
  turnNumber     String   
  customerName   String?  @default("Cliente")
  customerPhone  String?  
  customerEmail  String?
  orderType      String   
  paymentMethod  String   
  items          Json     
  orderNotes     String?  
  totalAmount    Float    // Lo que costó la comida
  pointsDiscount Float    @default(0) // El descuento aplicado por lealtad
  tipAmount      Float    @default(0) 
  status         String   @default("PENDING") 
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
