// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider ="prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- MODELOS DE CATÁLOGO ---

model Product {
  id          String     @id
  name        String
  category    String     // ESQUITE, ESPECIALIDAD, BEBIDA, ANTOJO, COMBO
  basePrice   Float
  description String?
  isCombo     Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Modifier {
  id        String   @id @default(uuid())
  name      String
  type      String   // POLVO, ADEREZO, QUESO, RESTRICCION
  price     Float    @default(0)
  createdAt DateTime @default(now())
}

// --- MODELO DE OPERACIONES (EL NUEVO CORAZÓN) ---

model Order {
  id            String   @id @default(uuid())
  turnNumber    String   // Ejemplo: M492
  customerName  String?  @default("Cliente")
  orderType     String   // DINE_IN o TAKEOUT
  paymentMethod String   // TERMINAL o EFECTIVO_CAJA
  
  // Guardamos el carrito completo como JSON para no perder detalle de los toppings
  items         Json     
  
  orderNotes    String?  // Comentarios para la cocina
  
  totalAmount   Float    // Monto de los productos
  tipAmount     Float    @default(0) // Propina agregada
  
  status        String   @default("PENDING") // PENDING, COMPLETED, CANCELED
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
