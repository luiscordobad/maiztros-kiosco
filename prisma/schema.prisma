generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id
  name        String
  category    String   
  basePrice   Float
  description String?
  isCombo     Boolean  @default(false)
  isAvailable Boolean  @default(true) 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Modifier {
  id          String   @id @default(uuid())
  name        String
  type        String   
  price       Float    @default(0)
  isAvailable Boolean  @default(true) 
  createdAt   DateTime @default(now())
}

model Customer {
  phone     String   @id
  name      String?
  points    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id            String   @id @default(uuid())
  code          String   @unique
  discount      Float    
  discountType  String   
  minAmount     Float    @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model Shift {
  id           String   @id @default(uuid())
  openedAt     DateTime @default(now())
  closedAt     DateTime?
  openedBy     String
  startingCash Float
  reportedCash Float?
  status       String   @default("OPEN") 
  orders       Order[]
  movements    CashMovement[]
}

model CashMovement {
  id        String   @id @default(uuid())
  shiftId   String
  shift     Shift    @relation(fields: [shiftId], references: [id])
  type      String   
  amount    Float
  reason    String
  createdAt DateTime @default(now())
}

model InventoryItem {
  id          String   @id @default(uuid())
  name        String   @unique
  category    String
  stock       Float    @default(0)
  unit        String   @default("pz")
  isAvailable Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model Order {
  id             String   @id @default(uuid())
  turnNumber     String   
  customerName   String?  @default("Cliente")
  customerPhone  String?  
  customerEmail  String?
  orderType      String   
  paymentMethod  String   
  items          Json     
  orderNotes     String?  
  totalAmount    Float    
  pointsDiscount Float    @default(0) 
  couponCode     String?  
  tipAmount      Float    @default(0) 
  status         String   @default("PENDING") 
  shiftId        String?  
  shift          Shift?   @relation(fields: [shiftId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// NUEVO: CONTABILIDAD Y GASTOS
model Expense {
  id          String   @id @default(uuid())
  amount      Float
  category    String   // INSUMOS, SERVICIOS, NOMINA, OTROS
  description String
  date        DateTime @default(now())
}
