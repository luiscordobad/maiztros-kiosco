// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- MODELOS DE CATÁLOGO ---

model Product {
  id          String   @id
  name        String
  category    String   // ESQUITE, ESPECIALIDAD, BEBIDA, ANTOJO, COMBO
  basePrice   Float
  description String?
  isCombo     Boolean  @default(false)
  isAvailable Boolean  @default(true) // <-- EL NUEVO SWITCH DE INVENTARIO
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Modifier {
  id          String   @id @default(uuid())
  name        String
  type        String   // POLVO, ADEREZO, QUESO, RESTRICCION, CHILE
  price       Float    @default(0)
  isAvailable Boolean  @default(true) // <-- EL NUEVO SWITCH DE INVENTARIO
  createdAt   DateTime @default(now())
}

// --- MODELO DE OPERACIONES (EL CORAZÓN) ---

model Order {
  id            String   @id @default(uuid())
  turnNumber    String   // Ejemplo: M492
  customerName  String?  @default("Cliente")
  orderType     String   // DINE_IN o TAKEOUT
  paymentMethod String   // TERMINAL o EFECTIVO_CAJA
  
  // Guardamos el carrito completo como JSON
  items         Json     
  
  orderNotes    String?  // Comentarios para la cocina
  
  totalAmount   Float    // Monto de los productos
  tipAmount     Float    @default(0) // Propina agregada
  
  status        String   @default("PENDING") // AWAITING_PAYMENT, PAID, COMPLETED
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
