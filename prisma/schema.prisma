generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ... (Product, Modifier, Customer, Coupon siguen igual)

model Shift {
  id           String   @id @default(uuid())
  openedAt     DateTime @default(now())
  closedAt     DateTime?
  openedBy     String
  startingCash Float
  reportedCash Float?   // Lo que el empleado dice que hay
  status       String   @default("OPEN") 
  orders       Order[]
  movements    CashMovement[] // <-- NUEVO
}

model CashMovement {
  id        String   @id @default(uuid())
  shiftId   String
  shift     Shift    @relation(fields: [shiftId], references: [id])
  type      String   // IN o OUT
  amount    Float
  reason    String
  createdAt DateTime @default(now())
}

model Order {
  id             String   @id @default(uuid())
  turnNumber     String   
  customerName   String?  @default("Cliente")
  customerPhone  String?  
  customerEmail  String?
  orderType      String   
  paymentMethod  String   
  items          Json     
  orderNotes     String?  
  totalAmount    Float    
  pointsDiscount Float    @default(0) 
  couponCode     String?  
  tipAmount      Float    @default(0) 
  status         String   @default("PENDING") 
  shiftId        String?  
  shift          Shift?   @relation(fields: [shiftId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
